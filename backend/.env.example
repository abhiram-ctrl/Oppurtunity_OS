# Environment Configuration Guide for Opportunity OS Backend

# MongoDB Connection (already existing)
MONGODB_URI=your_mongodb_connection_string_here
# Gemini API Configuration
# How to get your GEMINI_API_KEY:
# 1. Go to https://makersuite.google.com/app/apikey
# 2. Click "Create API Key" button
# 3. Copy the generated API key
# 4. Paste it below

GEMINI_API_KEY=your_generated_api_key_here

# Example .env file:
# GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxx
